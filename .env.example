# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Fireworks AI — https://fireworks.ai/
FIREWORKS_API_KEY=
# Full model id, e.g. accounts/fireworks/models/qwen3-235b-a22b-instruct
FIREWORKS_MODEL=

# Self-hosted SearXNG JSON endpoint, e.g. http://localhost:8080
# Run separately via: docker run --rm -p 8080:8080 -e SEARXNG_SECRET=$(openssl rand -hex 32) searxng/searxng
SEARXNG_URL=http://localhost:8080

# Optional: how many top results to fetch and extract (default 3)
SEARCH_TOP_N=3
